
[commit]
    template = ~/.gitmessage

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

[merge]
    conflictStyle = zdiff3


[alias]
        su = ! git submodule sync --recursive && git submodule  update --init --recursive
[user]
        email = shynn.lawrence@gmail.com
        name = Shynn Lawrence
[filter "lfs"]
        process = git-lfs filter-process
        required = true
        clean = git-lfs clean -- %f
        smudge = git-lfs smudge -- %f
[rerere]
        enabled = true
[alias]
    # Difftastic aliases, so `git difft` / `git dlog` / `git dshow` opt in
    # explicitly without changing the default `git diff` behavior.
    difft = -c diff.external=difft diff
    dlog = -c diff.external=difft log --ext-diff
    dshow = -c diff.external=difft show --ext-diff
    ddiff = -c diff.external=difft diff


[submodule]
        recurse = false
        fetchJobs = 0
[fetch]
        recurseSubmodules = on-demand
        parallel = 0
[init]
	defaultBranch = main
[core]
	editor = nvim
    pager = delta
[push]
	autoSetupRemote = true
	recurseSubmodules = no
[url "git@github.com:"]
	insteadOf = https://github.com/
