# ~/.config/wofi/config
# Centered, single-monitor launcher with fuzzy matching

mode=drun
matching=fuzzy
allow-images=true
no-actions=true
insensitive=true
# Use your terminal
term=foot
# Prompt text
prompt=Search…

# Positioning
location=center
width=800
height=420

# Behavior
hide-scroll=true
dpi-aware=true
columns=1
show=drun
